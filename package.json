		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.2.7",
		"msw": "^2.12.10",
		"prettier": "^3.7.4",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.46.4",
