		"axios": "^1.13.5",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"framer-motion": "^12.38.0",
		"lucide-react": "^1.8.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-error-boundary": "^6.1.1",
		"react-hook-form": "^7.69.0",
		"react-router": "^7.12.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.1.18",
		"zod": "^4.2.1",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@testing-library/jest-dom": "^6.9.1",
